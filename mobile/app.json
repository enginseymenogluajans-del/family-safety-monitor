{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enginseymen.familysafetymonitor",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "package": "com.enginseymen.mobile"
    },
    "plugins": ["expo-asset"],
    "extra": {
      "BACKEND_URL": "http://192.168.1.138:8000",
      "API_KEY": "suCi7-_40F_ca1kmd62hsddmBR1fGvorOEPXKxWQJNM",
      "eas": {
        "projectId": "4959a902-dce3-4844-b625-e1fb89cbbbf3"
      }
    },
    "owner": "enginseymen"
  }
}
