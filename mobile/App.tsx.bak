// SettingsScreen + ProfileCreateScreen ortak form stilleri
const g = StyleSheet.create({
  section: {
    backgroundColor: C.surface,
    borderRadius: 16,
    borderWidth: 1,
    borderColor: C.border,
    padding: 16,
    marginBottom: 4,
  },
  fieldLabel: {
    color: C.muted,
    fontSize: 10,
    fontWeight: "700",
    letterSpacing: 1.5,
    marginBottom: 6,
    marginTop: 12,
  },
