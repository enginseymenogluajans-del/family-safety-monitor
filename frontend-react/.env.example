# Backend API URL (varsayılan: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# API Kimlik Doğrulama Anahtarı
# backend/.env dosyasındaki API_SECRET_KEY ile aynı olmalı.
# Boş bırakılırsa backend'e kimlik doğrulamasız bağlanılır (401 hatası alırsınız).
VITE_API_KEY=

# WhatsApp Agent URL (varsayılan: http://localhost:3001)
VITE_WA_URL=http://localhost:3001

# Kilit ekranı şifresi
VITE_PASSCODE=1234

# Supabase Realtime Entegrasyonu
# Supabase konsolundan (Settings -> API) alınacak URL ve anon key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

