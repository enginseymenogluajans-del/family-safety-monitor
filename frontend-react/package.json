{
  "name": "family-safety-monitor",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "node launch-electron.js",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:build:dir": "vite build && electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.2.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.familysafety.monitor",
    "productName": "Family Safety Monitor",
    "asar": true,
    "asarUnpack": [
      "electron/icon.png"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend-resources/backend",
        "filter": [
          "**/*",
          "!__pycache__",
          "!*.pyc",
          "!.env",
          "!.env.*"
        ]
      },
      {
        "from": "../WebRTC/server",
        "to": "backend-resources/WebRTC/server",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      },
      {
        "from": "../whatsapp-agent",
        "to": "backend-resources/whatsapp-agent",
        "filter": [
          "**/*",
          "!node_modules",
          "!data",
          "!.wwebjs_auth"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Family Safety Monitor"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png",
      "category": "Utility"
    }
  }
}
