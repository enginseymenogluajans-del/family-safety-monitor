<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1A0A2E" />
            <stroke android:width="1dp" android:color="#7B00FF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0F0A1A" />
            <stroke android:width="1dp" android:color="#4D6600CC" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
