<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- ── Logo + Başlık ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="52dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡"
                    android:textSize="42sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Family Guard"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorText"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Güvenlik Ajanı"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Durum Kartı ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/dotConnectionStatus"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/circle_dot" />

                    <TextView
                        android:id="@+id/tvProtectionStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Koruma Aktif"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorStatusActive"
                        android:paddingStart="10dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/tvConnectionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Backend bağlantısı kontrol ediliyor..."
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary" />
            </LinearLayout>

            <!-- ── Yapılandırma Kartı ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BACKEND URL"
                    android:textSize="10sp"
                    android:textColor="@color/colorTextSecondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etBackendUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="http://192.168.1.100:8000"
                    android:inputType="textUri"
                    android:textColor="@color/colorText"
                    android:textColorHint="@color/colorTextSecondary"
                    android:background="@drawable/bg_input_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROFİL ID"
                    android:textSize="10sp"
                    android:textColor="@color/colorTextSecondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etProfileId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="default"
                    android:textColor="@color/colorText"
                    android:textColorHint="@color/colorTextSecondary"
                    android:background="@drawable/bg_input_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="KAYDET"
                    android:background="@drawable/bg_button_secondary"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- ── İzin Butonu ── -->
            <Button
                android:id="@+id/btnPermission"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="İZİN ADIMINI BAŞLAT"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/colorAccent"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:layout_marginBottom="10dp" />

            <!-- ── Ana Aksiyon Butonu ── -->
            <Button
                android:id="@+id/btnStartService"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="İZLEMEYİ BAŞLAT"
                android:background="@drawable/bg_button_purple"
                android:textColor="@color/colorText"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="16dp" />

            <!-- ── Log Kartı ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DURUM LOGU"
                    android:textSize="10sp"
                    android:textColor="@color/colorTextSecondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <ScrollView
                    android:id="@+id/scrollStatus"
                    android:layout_width="match_parent"
                    android:layout_height="200dp">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Durum kontrol ediliyor..."
                        android:textSize="11sp"
                        android:textColor="#CCCCCC"
                        android:lineSpacingExtra="4dp"
                        android:fontFamily="monospace" />
                </ScrollView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Ayarlar butonu (sağ üst köşe overlay) ── -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_manage"
        android:background="@drawable/bg_card_glass"
        android:tint="@color/colorTextSecondary"
        android:padding="10dp"
        android:contentDescription="Ayarlar" />

</FrameLayout>
