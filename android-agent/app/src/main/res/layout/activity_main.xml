<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- ── Üst bar ── -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Family Safety Agent"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:background="#1E1E1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnSettings" />

    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@android:drawable/ic_menu_manage"
        android:background="#1E1E1E"
        android:tint="#AAAAAA"
        android:contentDescription="Ayarlar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Hero: Koruma durumu ── -->
    <TextView
        android:id="@+id/tvProtectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬤  Koruma Aktif"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bağlantı durumu satırı ── -->
    <View
        android:id="@+id/dotConnectionStatus"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_dot"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvProtectionStatus"
        app:layout_constraintEnd_toStartOf="@+id/tvConnectionStatus"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Backend bağlantısı kontrol ediliyor..."
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:paddingStart="8dp"
        android:layout_marginTop="9dp"
        app:layout_constraintTop_toBottomOf="@id/tvProtectionStatus"
        app:layout_constraintStart_toEndOf="@+id/dotConnectionStatus"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Ayırıcı ── -->
    <View
        android:id="@+id/divider1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#2A2A2A"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvConnectionStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Konfigürasyon alanları ── -->
    <TextView
        android:id="@+id/lblBackendUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Backend URL"
        android:textSize="11sp"
        android:textColor="#888888"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:paddingStart="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etBackendUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="http://192.168.1.100:8000"
        android:inputType="textUri"
        android:textColor="#FFFFFF"
        android:textColorHint="#555555"
        android:background="#1E1E1E"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/lblBackendUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/lblProfileId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Profil ID"
        android:textSize="11sp"
        android:textColor="#888888"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:paddingStart="20dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/etBackendUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etProfileId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="default"
        android:textColor="#FFFFFF"
        android:textColorHint="#555555"
        android:background="#1E1E1E"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/lblProfileId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="KAYDET"
        android:backgroundTint="#333333"
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/etProfileId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Aksiyon butonları ── -->
    <Button
        android:id="@+id/btnPermission"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="İZİN ADIMINI BAŞLAT"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnSave"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnStartService" />

    <Button
        android:id="@+id/btnStartService"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="İZLEMEYİ BAŞLAT"
        android:backgroundTint="#1B5E20"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnSave"
        app:layout_constraintStart_toEndOf="@+id/btnPermission"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Durum logu (kaydırılabilir) ── -->
    <ScrollView
        android:id="@+id/scrollStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnPermission"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Durum kontrol ediliyor..."
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:background="#1A1A1A"
            android:padding="14dp"
            android:lineSpacingExtra="5dp"
            android:fontFamily="monospace" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
