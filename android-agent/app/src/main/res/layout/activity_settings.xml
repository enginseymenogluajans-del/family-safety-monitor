<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── Üst Bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?android:attr/selectableItemBackground"
                android:tint="#AAAAAA"
                android:contentDescription="Geri" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ayarlar"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ── Profil Bilgileri ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROFİL BİLGİLERİ"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Backend URL"
                android:textSize="11sp"
                android:textColor="#777777" />

            <TextView
                android:id="@+id/tvBackendUrlInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Profil ID"
                android:textSize="11sp"
                android:textColor="#777777" />

            <TextView
                android:id="@+id/tvProfileIdInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ── Bağlantı ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BAĞLANTI"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <Button
                android:id="@+id/btnRefreshConnection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BAĞLANTIYI YENİLE"
                android:backgroundTint="#1565C0"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GİRİŞ YAP"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ÇIKIŞ YAP"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ── Şifre Değiştir ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ŞİFRE DEĞİŞTİR"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <EditText
                android:id="@+id/etCurrentPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mevcut şifre"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A2A"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Yeni şifre"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A2A"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Yeni şifre (tekrar)"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A2A"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ŞİFREYİ GÜNCELLE"
                android:backgroundTint="#37474F"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ── Şifre İpucu ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ŞİFRE İPUCU (HATIRLATICI KELİME)"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvCurrentHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="İpucu yok"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etPasswordHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Hatırlatıcı kelime (örn: evcil hayvan adı)"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A2A"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSaveHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="İPUCUNU KAYDET"
                android:backgroundTint="#37474F"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ── Gizli Mod ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GİZLİ MOD"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvIconStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Simge görünür"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnToggleIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SİMGEYİ GİZLE / GÖSTER"
                android:backgroundTint="#263238"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ── Uygulama Şifresi (Device Admin) ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UYGULAMA KALDIRILMA ŞİFRESİ"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvAppPasswordStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Şifre ayarlanmamış"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etAppPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Uygulama kaldırma şifresi"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A2A"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSetAppPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ŞIFREYI AYARLA"
                android:backgroundTint="#4A148C"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnClearAppPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ŞİFREYİ KALDIR"
                android:backgroundTint="#37474F"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
