# API Kimlik Doğrulama
# Boş bırakırsanız ilk çalıştırmada otomatik üretilir ve konsola yazdırılır.
# Üretilen değeri frontend-react/.env dosyasındaki VITE_API_KEY ile eşleştirin.
API_SECRET_KEY=

# iCloud oturum dizini (pyicloud cookie'leri burada saklar)
ICLOUD_COOKIE_DIR=../credentials

# Gmail OAuth
GMAIL_CREDENTIALS_PATH=../credentials/gmail_oauth.json
GMAIL_TOKEN_DIR=../credentials

# E-posta bildirimleri (SMTP)
# Gmail için: App Password kullanın (2FA açıksa)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=senin@gmail.com
SMTP_PASS=uygulama-sifresi-buraya
FROM_EMAIL=senin@gmail.com

# Telegram Bildirimleri (isteğe bağlı — e-postanın yanına eklenir)
# 1) Telegram'da @BotFather'a /newbot yaz → token'ı al
# 2) Botuna bir mesaj gönder, sonra tarayıcıda aç:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    "chat":{"id": XXXXXXX} → o sayı CHAT_ID'ndir
TELEGRAM_BOT_TOKEN=1234567890:ABCDefghIJKlmNOPqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789
